<%- include("partials/app-start", {
  pageTitle: "Customers",
  pageHeading: "Customers",
  pageSubtitle: "Add, edit, and manage your customer list.",
  activePage,
  counts
}) %>

<section class="two-col">
  <article class="card">
    <h2>Add Customer</h2>
    <form method="post" action="/customers" class="grid">
      <input type="text" name="name" placeholder="Customer name" required />
      <input type="text" name="phone" placeholder="Phone with country code" required />
      <input type="text" name="tags" placeholder="Tags (e.g. lead,vip)" />
      <button type="submit">Add Customer</button>
    </form>
  </article>
  <article class="card">
    <h2>Import Customers (CSV)</h2>
    <form method="post" action="/customers/import-csv" enctype="multipart/form-data" class="grid">
      <input type="file" name="customersCsv" accept=".csv,text/csv" required />
      <input type="text" name="source" placeholder="Source label (optional, e.g. april-leads)" />
      <button type="submit">Upload CSV</button>
    </form>
    <p class="muted">
      Required column: <strong>phone</strong>. Optional: <strong>name</strong>, <strong>tags</strong>.
      Duplicate phones are skipped automatically.
    </p>
    <% if (importSummary?.error) { %>
    <p class="danger-note"><%= importSummary.error %></p>
    <% } %>
    <% if ((importSummary?.added || importSummary?.skipped || importSummary?.invalid) && importSummary?.source) { %>
    <p>
      Import result for "<%= importSummary.source %>": added <strong><%= importSummary.added %></strong>,
      skipped duplicates <strong><%= importSummary.skipped %></strong>, invalid rows
      <strong><%= importSummary.invalid %></strong>.
    </p>
    <% } %>
  </article>
</section>

<section class="card">
  <% const qNav = typeof searchQuery === 'string' && searchQuery ? ('&q=' + encodeURIComponent(searchQuery)) : ''; %>
  <h2><%= pagination.searchActive ? 'Search Results' : 'All Customers' %> (<%= pagination.searchActive ? pagination.totalMatching : counts.customers %>)</h2>
  <form method="get" action="/customers" class="customer-search-row">
    <input type="hidden" name="page" value="1" />
    <input
      type="search"
      name="q"
      value="<%= typeof searchQuery === 'string' ? searchQuery : '' %>"
      placeholder="Search by name, phone, tags..."
      autocomplete="off"
      class="customer-search-input"
    />
    <button type="submit">Search</button>
    <% if (pagination.searchActive) { %>
    <a class="button ghost" href="/customers">Clear</a>
    <% } %>
  </form>
  <div class="actions">
    <div>
      <span class="muted">Page <strong><%= pagination.page %></strong> of <strong><%= pagination.totalPages %></strong></span>
      <% if (pagination.hasPrev) { %>
      <a class="button ghost" href="/customers?page=<%= pagination.page - 1 %><%= qNav %>">Previous</a>
      <% } %>
      <% if (pagination.hasNext) { %>
      <a class="button ghost" href="/customers?page=<%= pagination.page + 1 %><%= qNav %>">Next</a>
      <% } %>
    </div>
    <form
      method="post"
      action="/customers/delete-all"
      onsubmit="return confirm('Delete ALL customers and message history?')"
    >
      <button type="submit" class="danger">Delete All Customer Data</button>
    </form>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Phone</th>
          <th>Tags</th>
          <th>Owner</th>
          <th>Consent</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% customers.forEach((c) => { %>
        <tr>
          <td><%= c.name %></td>
          <td><%= c.phone %></td>
          <td><%= c.tags %></td>
          <td>
            <form method="post" action="/customers/<%= c.id %>/assign">
              <input type="text" name="assignedAgent" value="<%= c.assigned_agent || '' %>" placeholder="Agent name" />
              <button type="submit" class="secondary">Assign</button>
            </form>
          </td>
          <td>
            <% if (c.is_opted_out) { %>
            <form method="post" action="/customers/<%= c.id %>/opt-in">
              <button type="submit" class="secondary">Opted Out (Enable)</button>
            </form>
            <% } else { %>
            <form method="post" action="/customers/<%= c.id %>/opt-out">
              <button type="submit" class="danger">Opt Out</button>
            </form>
            <% } %>
          </td>
          <td class="actions-cell">
            <a class="button ghost" href="/customers/<%= c.id %>">Profile</a>
            <form
              method="post"
              action="/customers/<%= c.id %>/delete"
              onsubmit="return confirm('Delete this customer and their messages?')"
            >
              <button type="submit" class="danger">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include("partials/app-end") %>
